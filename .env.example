# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Digital signature (PKCS#12 / .p12) ---
# Path inside the container. docker-compose.yml bind-mounts ./secrets on
# the host to /run/secrets in the container, so place your .p12 file at
# `./secrets/signing.p12` (the host path) for the default value below to
# work unchanged.
SIGNATURE_P12_PATH=/run/secrets/signing.p12
SIGNATURE_P12_PASSWORD=changeme
SIGNATURE_FIELD_NAME=PickAtRandomSig1
SIGNATURE_REASON=Naključno razvrščanje seznama

# --- I/O paths (inside the container) ---
INPUT_DIR=/data/in
OUTPUT_DIR=/data/out

# --- Randomization (NTP-seeded) ---
# Hostname of the NTP server queried to seed the shuffle.
# `time.arnes.si` is the Slovenian national reference; `pool.ntp.org` is a
# good public default.
NTP_SERVER=ntp1.arnes.si
NTP_TIMEOUT_SECONDS=5
NTP_VERSION=4

# --- Locale / formatting ---
APP_LOCALE=sl_SI
APP_TIMEZONE=Europe/Ljubljana

# --- Host identity (optional) ---
# When running inside Docker `socket.gethostname()` returns the container ID
# and `getpass.getuser()` returns the in-container user — neither is useful on
# the report. Set the variables below (or pass them through `docker compose`)
# to record the actual operator. Leave blank to omit the corresponding row
# from the PDF entirely.
HOST_HOSTNAME=
HOST_USERNAME=
